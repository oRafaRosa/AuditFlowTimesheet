# exemplo de configuração das variáveis de ambiente
# copia esse arquivo pra .env e preenche com as tuas credenciais

# credenciais do supabase
VITE_SUPABASE_URL=sua_url_aqui
VITE_SUPABASE_KEY=sua_key_aqui

# criptografia da Matriz de Riscos (mínimo 16 caracteres)
# Gere uma chave segura e guarde em um Secret Manager (nunca no Git)
VITE_RISK_MATRIX_ENCRYPTION_KEY=sua_chave_segura_aqui_minimo_16_chars
